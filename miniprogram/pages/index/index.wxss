/* miniprogram/pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2196F3 0%, #1976D2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  margin-top: 60rpx;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.key-input {
  width: 100%;
  height: 100rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  font-size: 40rpx;
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: bold;
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #2196F3;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(33, 150, 243, 0.4);
}

.btn-primary[disabled] {
  background: #ccc;
  box-shadow: none;
}
